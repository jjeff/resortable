{
  "name": "resortable",
  "version": "2.0.3",
  "description": "Modern TypeScript rewrite of Sortable.js - reorderable drag-and-drop lists",
  "type": "module",
  "main": "dist/sortable.cjs",
  "module": "dist/sortable.esm.js",
  "unpkg": "dist/sortable.umd.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/sortable.esm.js",
      "require": "./dist/sortable.cjs"
    },
    "./react": {
      "types": "./dist/types/react/index.d.ts",
      "import": "./dist/react/index.esm.js",
      "require": "./dist/react/index.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "react": [
        "./dist/types/react/index.d.ts"
      ],
      "*": [
        "./dist/types/index.d.ts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "dev:debug": "NODE_OPTIONS='--inspect' vite",
    "build": "tsc && vite build && vite build --config vite.config.react.ts",
    "build:debug": "NODE_OPTIONS='--inspect-brk' npm run build",
    "build:rollup": "rollup -c",
    "build:examples": "vite build --config vite.config.examples.ts",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "npm run lint:fix",
    "format:check": "npm run lint",
    "check": "npm run lint && npm run type-check",
    "clean": "rimraf dist",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:unit:debug": "NODE_OPTIONS='--inspect-brk' vitest run",
    "test:unit:watch": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:install": "playwright install",
    "commit": "cz",
    "semantic-release": "semantic-release",
    "docs:build": "typedoc",
    "docs:serve": "npx http-server docs -p 8080",
    "docs:clean": "rimraf docs/api",
    "size": "size-limit",
    "size:build": "npm run build && npm run size"
  },
  "size-limit": [
    {
      "name": "ESM (gzip)",
      "path": "dist/sortable.esm.js",
      "limit": "50 kB",
      "gzip": true,
      "brotli": false
    },
    {
      "name": "CJS (gzip)",
      "path": "dist/sortable.cjs",
      "limit": "30 kB",
      "gzip": true,
      "brotli": false
    },
    {
      "name": "UMD (gzip)",
      "path": "dist/sortable.umd.js",
      "limit": "30 kB",
      "gzip": true,
      "brotli": false
    },
    {
      "path": "dist/react/index.esm.js",
      "limit": "5 kB"
    }
  ],
  "keywords": [
    "sortable",
    "drag-and-drop",
    "reorderable",
    "typescript",
    "dnd",
    "ui",
    "interaction"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jjeff/resortable.git"
  },
  "bugs": {
    "url": "https://github.com/jjeff/resortable/issues"
  },
  "homepage": "https://github.com/jjeff/resortable#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.34.0",
    "@microsoft/tsdoc": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.1.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@size-limit/file": "^12.1.0",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "@vitest/ui": "^3.2.6",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-tsdoc": "^0.4.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rimraf": "^6.0.1",
    "rollup-plugin-dts": "^6.2.3",
    "semantic-release": "^25.0.6",
    "size-limit": "^12.1.0",
    "typedoc": "^0.28.12",
    "typescript": "^5.9.2",
    "vite": "^7.3.5",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "handlebars": "^4.7.9",
    "minimatch@3": "^3.1.3",
    "minimatch@9": "^9.0.7",
    "minimatch@10": "^10.2.3",
    "glob@11": "^11.1.0",
    "tmp": "^0.2.6",
    "ws": "^8.21.0",
    "js-yaml": "^4.2.0",
    "markdown-it": "^14.2.0",
    "picomatch@2": "^2.3.2",
    "flatted": "^3.4.2",
    "brace-expansion@2": "^2.0.3",
    "esbuild": "^0.28.1",
    "rollup": "^4.59.0",
    "lodash": "^4.18.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
